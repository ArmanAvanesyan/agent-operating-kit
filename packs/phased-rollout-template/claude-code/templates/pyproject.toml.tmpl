[project]
name = "{{PROJECT_NAME}}"
version = "0.0.1"
description = "{{PROJECT_DESCRIPTION}}"
readme = "README.md"
requires-python = ">=3.12,<3.13"
license = { text = "Proprietary" }

dependencies = [
    # Web framework
    "fastapi>=0.115.0",
    "uvicorn[standard]>=0.32.0",
    "pydantic>=2.9.0",
    "pydantic-settings>=2.6.0",

    # Database (drop these if your project doesn't use Postgres)
    "sqlalchemy[asyncio]>=2.0.36",
    "asyncpg>=0.30.0",
    "alembic>=1.14.0",

    # HTTP client
    "httpx>=0.28.0",

    # Observability
    "sentry-sdk[fastapi]>=2.19.0",
    "opentelemetry-api>=1.29.0",
    "opentelemetry-sdk>=1.29.0",
    "opentelemetry-instrumentation-fastapi>=0.50b0",
    "structlog>=24.4.0",
]

[project.optional-dependencies]
dev = [
    "pytest>=8.3.0",
    "pytest-asyncio>=0.24.0",
    "pytest-cov>=6.0.0",
    "pytest-httpx>=0.34.0",
    "ruff>=0.8.0",
    "mypy>=1.13.0",
    "pre-commit>=4.0.0",
    "bandit>=1.8.0",
    "pip-audit>=2.7.0",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["app"]

# -------- Ruff --------
[tool.ruff]
line-length = 100
target-version = "py312"
extend-exclude = ["alembic/versions", ".claude"]

[tool.ruff.lint]
select = [
    "E", "W",       # pycodestyle
    "F",            # pyflakes
    "I",            # isort
    "B",            # bugbear
    "UP",           # pyupgrade
    "C4",           # comprehensions
    "SIM",          # simplify
    "ASYNC",        # async-specific
    "S",            # bandit (security)
    "N",            # pep8-naming
    "RUF",          # ruff-specific
]
ignore = [
    "S101",         # asserts ok in tests
    "B008",         # FastAPI's Depends() defaults
]

[tool.ruff.lint.per-file-ignores]
"tests/**" = ["S101", "S105", "S106", "S108", "F841", "RUF059"]

# -------- Mypy --------
[tool.mypy]
python_version = "3.12"
strict = true
plugins = ["pydantic.mypy"]
exclude = ["alembic/versions"]

[[tool.mypy.overrides]]
module = ["opentelemetry.*", "sentry_sdk.*", "structlog.*"]
ignore_missing_imports = true

# -------- Pytest --------
[tool.pytest.ini_options]
testpaths = ["tests"]
asyncio_mode = "auto"
addopts = [
    "--strict-markers",
    "--strict-config",
    "--cov=app",
    "--cov-report=term-missing",
    "--cov-fail-under=70",
]
markers = [
    "integration: integration tests (slower, may hit external services with mocks)",
]

[tool.coverage.run]
omit = [
    "alembic/*",
    "tests/*",
    "scripts/*",
    # Infrastructure: DB engine/session, ORM schema declarations, observability
    # init, and route stubs are covered by integration tests, not unit tests.
    "app/db/*",
    "app/main.py",
    "app/models/*.py",
    "app/config.py",
    "app/observability/*",
]
