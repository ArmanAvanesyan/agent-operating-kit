#!/usr/bin/env python3
"""Agent Operating Kit command line interface."""

from __future__ import annotations

import argparse
import difflib
import json
import os
import re
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Iterable

try:
    import tomllib
except ModuleNotFoundError:  # pragma: no cover - Python < 3.11 fallback
    tomllib = None


KIT_ROOT = Path(__file__).resolve().parents[1]
PLUGIN_NAME = "agent-operating-kit"
MARKETPLACE_NAME = "private-local"
MARKETPLACE_DISPLAY = "Private Local"
CLAUDE_MARKETPLACE_NAME = "aok-claude-code"
CLAUDE_ROOT_PLUGIN = "agent-operating-kit"
SUPPORTED_TARGETS = (
    "codex",
    "claude-code",
    "cursor",
    "opencode",
    "gemini",
    "openclaw",
    "hermes-agent",
)
RENDER_TARGETS = SUPPORTED_TARGETS + ("all",)
CODEX_LOCAL_ENV_DOCS_URL = "https://developers.openai.com/codex/app/local-environments"
CODEX_LOCAL_ENV_REQUIRED = (
    ".codex/config.toml",
    ".codex/setup.sh",
    ".codex/aok-action.sh",
    ".codex/aok-local-environment.json",
    ".codex/environments/environment.toml",
)
CODEX_LOCAL_ENV_ACTIONS = (
    "AOK Doctor",
    "AOK Validate",
    "AOK Render Bundles",
    "AOK Project Init",
    "AOK Claude Setup",
    "AOK Release Build",
)



class AokError(RuntimeError):
    pass


def run(cmd: list[str], cwd: Path | None = None, check: bool = True) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, cwd=cwd, text=True, capture_output=True, check=check)


def is_windows_host() -> bool:
    return os.name == "nt"


def command_exists(name: str) -> bool:
    return shutil.which(name) is not None


def print_result(label: str, ok: bool, detail: str = "") -> None:
    mark = "OK" if ok else "FAIL"
    suffix = f" - {detail}" if detail else ""
    print(f"{mark} {label}{suffix}")


def load_json(path: Path, default: dict) -> dict:
    if not path.exists():
        return default
    try:
        return json.loads(path.read_text())
    except json.JSONDecodeError as exc:
        raise AokError(f"Invalid JSON in {path}: {exc}") from exc


def write_json(path: Path, data: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, indent=2, sort_keys=False) + "\n")


def load_simple_environment_toml(path: Path) -> dict:
    if tomllib is not None:
        return tomllib.loads(path.read_text())
    data: dict[str, object] = {"actions": []}
    current_action: dict[str, str] | None = None
    in_setup = False
    for raw_line in path.read_text().splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        if line == "[setup]":
            data.setdefault("setup", {})
            in_setup = True
            current_action = None
            continue
        if line == "[[actions]]":
            current_action = {}
            data.setdefault("actions", []).append(current_action)
            in_setup = False
            continue
        if "=" not in line:
            continue
        key, value = [part.strip() for part in line.split("=", 1)]
        parsed = value.strip('"') if value.startswith('"') and value.endswith('"') else int(value) if value.isdigit() else value
        if current_action is not None:
            current_action[key] = parsed
        elif in_setup:
            data.setdefault("setup", {})[key] = parsed
        else:
            data[key] = parsed
    return data


def resolve_targets(raw: str) -> tuple[str, ...]:
    if raw == "all":
        return SUPPORTED_TARGETS
    if raw not in SUPPORTED_TARGETS:
        raise AokError(f"Unsupported target: {raw}")
    return (raw,)


def normalize_pack_output(pack_name: str, target: str, explicit_out: Path | None, target_count: int) -> Path:
    if explicit_out is None:
        return KIT_ROOT / "build" / "renders" / pack_name / f"{target}.json"
    if explicit_out.suffix and target_count == 1:
        return explicit_out
    if explicit_out.suffix and explicit_out.name == explicit_out.stem:
        return explicit_out / f"{pack_name}.{target}.json"
    return explicit_out / f"{pack_name}.{target}.json"


def find_pack_dirs() -> list[str]:
    pack_root = KIT_ROOT / "packs"
    return sorted([path.name for path in pack_root.glob("*") if path.is_dir()])


def load_pack_manifest(pack_name: str) -> tuple[dict, Path]:
    pack_dir = KIT_ROOT / "packs" / pack_name
    manifest_path = pack_dir / "pack.json"
    if not pack_dir.exists() or not pack_dir.is_dir():
        raise AokError(f"Unknown pack: {pack_name}")
    if not manifest_path.exists():
        raise AokError(f"Missing pack manifest: {manifest_path}")
    manifest = load_json(manifest_path, {})
    if not isinstance(manifest, dict):
        raise AokError(f"Invalid pack manifest: {manifest_path}")
    if not manifest:
        raise AokError(f"Invalid pack manifest: {manifest_path}")
    return manifest, pack_dir


def load_pack_content(pack_name: str, pack_dir: Path, manifest: dict) -> tuple[dict, Path]:
    content_rel = manifest.get("neutralContent", "pack.content.json")
    content_path = pack_dir / content_rel
    if not content_path.exists():
        raise AokError(f"Missing neutral pack content file: {content_path}")
    content = load_json(content_path, {})
    if not isinstance(content, dict):
        raise AokError(f"Missing or invalid neutral pack content: {content_path}")
    return content, content_path


def user_home(raw: str | None = None) -> Path:
    return Path(raw).expanduser().resolve() if raw else Path.home()


def marketplace_paths(home: Path | None = None) -> tuple[Path, Path]:
    home = home or Path.home()
    root = home / ".agents" / "plugins"
    return root / "marketplace.json", root / "plugins" / PLUGIN_NAME


def cli_shim_path(home: Path | None = None) -> Path:
    home = home or Path.home()
    bin_dir = home / ".local" / "bin"
    return bin_dir / ("aok.cmd" if is_windows_host() else "aok")


def remove_existing_path(path: Path) -> None:
    if path.is_dir() and not path.is_symlink():
        shutil.rmtree(path)
    else:
        path.unlink()


def plugin_dir_looks_valid(path: Path) -> bool:
    manifest_path = path / ".codex-plugin" / "plugin.json"
    if not manifest_path.exists():
        return False
    try:
        data = json.loads(manifest_path.read_text())
    except json.JSONDecodeError:
        return False
    return data.get("name") == PLUGIN_NAME


def create_windows_junction(link_path: Path, target: Path) -> bool:
    result = subprocess.run(
        ["cmd", "/c", "mklink", "/J", str(link_path), str(target)],
        text=True,
        capture_output=True,
        check=False,
    )
    return result.returncode == 0


def ensure_plugin_path(link_path: Path, replace: bool) -> str:
    current_matches = False
    existing_mode = ""
    if link_path.exists() or link_path.is_symlink():
        try:
            current_matches = link_path.resolve() == KIT_ROOT
        except OSError:
            current_matches = False
        if current_matches:
            return "symlink" if link_path.is_symlink() else "junction"
        if is_windows_host() and plugin_dir_looks_valid(link_path):
            existing_mode = "copy"
            current_matches = True
        if current_matches:
            return existing_mode
        if not replace:
            raise AokError(f"Refusing to replace existing plugin path: {link_path}")
        remove_existing_path(link_path)

    if not is_windows_host():
        link_path.symlink_to(KIT_ROOT, target_is_directory=True)
        return "symlink"

    if create_windows_junction(link_path, KIT_ROOT):
        return "junction"
    shutil.copytree(KIT_ROOT, link_path)
    return "copy"


def windows_cli_shim_text(target_script: Path) -> str:
    target = str(target_script)
    return (
        "@echo off\n"
        "setlocal\n"
        "where py >nul 2>nul\n"
        "if %ERRORLEVEL%==0 (\n"
        f'  py -3 "{target}" %*\n'
        ") else (\n"
        f'  python "{target}" %*\n'
        ")\n"
    )


def ensure_cli_shim(home: Path, replace: bool) -> tuple[Path, str]:
    bin_dir = home / ".local" / "bin"
    bin_dir.mkdir(parents=True, exist_ok=True)

    if not is_windows_host():
        bin_link = bin_dir / "aok"
        if bin_link.exists() or bin_link.is_symlink():
            if not (bin_link.is_symlink() and bin_link.resolve() == KIT_ROOT / "scripts" / "aok"):
                if replace:
                    remove_existing_path(bin_link)
                    bin_link.symlink_to(KIT_ROOT / "scripts" / "aok")
                else:
                    raise AokError(f"Refusing to replace existing executable: {bin_link}")
        else:
            bin_link.symlink_to(KIT_ROOT / "scripts" / "aok")
        return bin_link, "symlink"

    bin_link = bin_dir / "aok.cmd"
    shim_text = windows_cli_shim_text(KIT_ROOT / "scripts" / "aok")
    if bin_link.exists():
        if bin_link.read_text().replace("\r\n", "\n") != shim_text:
            if not replace:
                raise AokError(f"Refusing to replace existing executable: {bin_link}")
            bin_link.unlink()
            bin_link.write_text(shim_text, newline="\r\n")
    else:
        bin_link.write_text(shim_text, newline="\r\n")

    legacy_unix_shim = bin_dir / "aok"
    if legacy_unix_shim.exists() or legacy_unix_shim.is_symlink():
        if replace:
            remove_existing_path(legacy_unix_shim)
    return bin_link, "cmd"


def cmd_install(args: argparse.Namespace) -> int:
    home = user_home(getattr(args, "home", None))
    replace = bool(getattr(args, "replace", False))
    missing = [name for name in ("codex",) if not command_exists(name)]
    if missing:
        print(f"Warning: missing optional commands: {', '.join(missing)}", file=sys.stderr)
        print("Install continues; `aok doctor` reports optional capabilities separately.", file=sys.stderr)

    marketplace, link_path = marketplace_paths(home)
    link_path.parent.mkdir(parents=True, exist_ok=True)
    plugin_mode = ensure_plugin_path(link_path, replace)

    data = load_json(
        marketplace,
        {"name": MARKETPLACE_NAME, "interface": {"displayName": MARKETPLACE_DISPLAY}, "plugins": []},
    )
    data.setdefault("name", MARKETPLACE_NAME)
    data.setdefault("interface", {}).setdefault("displayName", MARKETPLACE_DISPLAY)
    plugins = data.setdefault("plugins", [])
    entry = {
        "name": PLUGIN_NAME,
        "source": {"source": "local", "path": f"./plugins/{PLUGIN_NAME}"},
        "policy": {"installation": "AVAILABLE", "authentication": "ON_INSTALL"},
        "category": "Productivity",
    }
    for idx, plugin in enumerate(plugins):
        if plugin.get("name") == PLUGIN_NAME:
            plugins[idx] = entry
            break
    else:
        plugins.append(entry)
    write_json(marketplace, data)

    bin_link, shim_mode = ensure_cli_shim(home, replace)

    print(f"Registered plugin in {marketplace}")
    print(f"Plugin path ({plugin_mode}): {link_path} -> {KIT_ROOT}")
    print(f"CLI path ({shim_mode}): {bin_link}")
    return 0


def collect_doctor(home: Path | None = None) -> dict:
    home = home or Path.home()
    required_files = [
        KIT_ROOT / ".codex-plugin" / "plugin.json",
        KIT_ROOT / "hooks.json",
        KIT_ROOT / "templates" / "AGENTS.md",
        KIT_ROOT / "templates" / "agents" / "workflow.md",
        KIT_ROOT / "templates" / ".codex" / "setup.sh",
        KIT_ROOT / "templates" / ".codex" / "aok-action.sh",
        KIT_ROOT / "templates" / ".codex" / "aok-local-environment.json",
        KIT_ROOT / "templates" / ".codex" / "environments" / "environment.toml",
        KIT_ROOT / "docs" / "codex-local-environments.md",
        KIT_ROOT / "scripts" / "aok",
    ]
    marketplace, link_path = marketplace_paths(home)
    cli_path = cli_shim_path(home)
    plugin_ok = link_path.exists() and (
        link_path.resolve() == KIT_ROOT or (is_windows_host() and plugin_dir_looks_valid(link_path))
    )
    commands = {
        name: {
            "ok": command_exists(name),
            "path": shutil.which(name),
            "required": False,
        }
        for name in ("git", "gh", "codex")
    }
    files = [
        {
            "path": str(path),
            "relativePath": str(path.relative_to(KIT_ROOT)),
            "ok": path.exists(),
        }
        for path in required_files
    ]
    install = {
        "marketplace": {
            "path": str(marketplace),
            "ok": marketplace.exists(),
        },
        "pluginPath": {
            "path": str(link_path),
            "ok": plugin_ok,
            "target": str(KIT_ROOT),
        },
        "cliShim": {
            "path": str(cli_path),
            "ok": cli_path.exists(),
        },
    }
    codex_local_environment = collect_codex_local_env(KIT_ROOT / "templates")
    required_ok = (
        all(item["ok"] for item in files)
        and install["marketplace"]["ok"]
        and install["pluginPath"]["ok"]
        and codex_local_environment["templatesOk"]
    )
    return {
        "kind": "aok-doctor-report",
        "version": plugin_version(),
        "kitRoot": str(KIT_ROOT),
        "home": str(home),
        "status": "ok" if required_ok else "needs-attention",
        "requiredOk": required_ok,
        "commands": commands,
        "files": files,
        "install": install,
        "codexLocalEnvironment": codex_local_environment,
        "nextActions": [] if required_ok else ["Run the AOK installer again or check the marketplace/plugin paths."],
    }


def doctor_report_text(report: dict) -> str:
    lines = [
        "# Agent Operating Kit Setup Report",
        "",
        f"Status: {report['status']}",
        f"Kit root: {report['kitRoot']}",
        f"Home: {report['home']}",
        "",
        "## Required Files",
    ]
    for item in report["files"]:
        lines.append(f"- {'OK' if item['ok'] else 'FAIL'} {item['relativePath']}")
    lines.extend(["", "## Installation"])
    for label, item in report["install"].items():
        lines.append(f"- {'OK' if item['ok'] else 'FAIL'} {label}: {item['path']}")
    lines.extend(["", "## Codex Local Environment"])
    local_env = report["codexLocalEnvironment"]
    lines.append(f"- {'OK' if local_env['templatesOk'] else 'FAIL'} templates: {local_env['projectPath']}")
    lines.append(f"- config schema status: {local_env['codexGeneratedConfig']['status']}")
    for item in local_env["files"]:
        lines.append(f"- {'OK' if item['ok'] else 'FAIL'} {item['relativePath']}")
    lines.extend(["", "## Optional Commands"])
    for name, item in report["commands"].items():
        detail = item["path"] or "not found"
        lines.append(f"- {'OK' if item['ok'] else 'MISSING'} {name}: {detail}")
    if report["nextActions"]:
        lines.extend(["", "## Next Actions"])
        for action in report["nextActions"]:
            lines.append(f"- {action}")
    return "\n".join(lines) + "\n"


def cmd_doctor(args: argparse.Namespace) -> int:
    report = collect_doctor(user_home(getattr(args, "home", None)))
    if getattr(args, "report", None):
        out = Path(args.report).expanduser()
        out.parent.mkdir(parents=True, exist_ok=True)
        out.write_text(doctor_report_text(report))
        print(f"Wrote setup report: {out}")
    if getattr(args, "json", False):
        print(json.dumps(report, indent=2))
    else:
        for name, item in report["commands"].items():
            print_result(f"optional command {name}", bool(item["ok"]), item["path"] or "not found")
        for item in report["files"]:
            print_result(item["relativePath"], bool(item["ok"]))
        install = report["install"]
        print_result("marketplace", install["marketplace"]["ok"], install["marketplace"]["path"])
        print_result("plugin path", install["pluginPath"]["ok"], install["pluginPath"]["path"])
        print_result("CLI shim", install["cliShim"]["ok"], install["cliShim"]["path"])
        local_env = report["codexLocalEnvironment"]
        print_result("Codex local environment templates", local_env["templatesOk"], local_env["projectPath"])
    return 0 if report["requiredOk"] else 1


def detect_workspace_kind(target: Path) -> str:
    if (target / ".git").exists():
        return "single-repo"
    child_repos = [p for p in target.iterdir() if p.is_dir() and (p / ".git").exists()]
    return "multi-repo" if child_repos else "plain-directory"


def backup_file(path: Path, backup_root: Path, target: Path) -> Path:
    rel = path.relative_to(target)
    dest = backup_root / rel
    dest.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(path, dest)
    return dest


def unified_diff(old: str, new: str, old_label: str, new_label: str) -> str:
    return "".join(
        difflib.unified_diff(
            old.splitlines(keepends=True),
            new.splitlines(keepends=True),
            fromfile=old_label,
            tofile=new_label,
        )
    )


def copy_template_tree(target: Path, force: bool = False) -> list[str]:
    template_root = KIT_ROOT / "templates"
    timestamp = datetime.now(timezone.utc).strftime("%Y%m%d%H%M%S")
    backup_root = target / ".aok-backups" / timestamp
    changes: list[str] = []

    for src in sorted(template_root.rglob("*")):
        if src.is_dir():
            continue
        rel = src.relative_to(template_root)
        dest = target / rel
        dest.parent.mkdir(parents=True, exist_ok=True)
        new_text = src.read_text()
        if not dest.exists():
            dest.write_text(new_text)
            if os.access(src, os.X_OK):
                dest.chmod(0o755)
            changes.append(f"created {rel}")
            continue
        old_text = dest.read_text()
        if old_text == new_text:
            changes.append(f"unchanged {rel}")
            continue
        if rel == Path("AGENTS.md") and not force:
            proposed = target / "AGENTS.aok-proposed.md"
            proposed.write_text(new_text)
            diff_path = target / "AGENTS.aok.diff"
            diff_path.write_text(unified_diff(old_text, new_text, "AGENTS.md", "AGENTS.aok-proposed.md"))
            changes.append(f"preserved AGENTS.md; wrote {proposed.name} and {diff_path.name}")
            continue
        backup = backup_file(dest, backup_root, target)
        dest.write_text(new_text)
        if os.access(src, os.X_OK):
            dest.chmod(0o755)
        changes.append(f"updated {rel}; backup {backup.relative_to(target)}")

    meta = target / ".aok"
    meta.mkdir(exist_ok=True)
    (meta / "project.json").write_text(
        json.dumps(
            {
                "initializedAt": datetime.now(timezone.utc).isoformat(timespec="seconds"),
                "workspaceKind": detect_workspace_kind(target),
                "kitVersion": plugin_version(),
            },
            indent=2,
        )
        + "\n"
    )
    changes.append("wrote .aok/project.json")
    return changes


def plugin_version() -> str:
    manifest = json.loads((KIT_ROOT / ".codex-plugin" / "plugin.json").read_text())
    return str(manifest.get("version", "unknown"))


def cmd_project_init(args: argparse.Namespace) -> int:
    target = Path(args.path).resolve()
    if not target.exists() or not target.is_dir():
        raise AokError(f"Target is not a directory: {target}")
    changes = copy_template_tree(target, force=args.force)
    print(f"Initialized {target}")
    print(f"Workspace kind: {detect_workspace_kind(target)}")
    for change in changes:
        print(f"- {change}")
    return 0


def validate_project(path: Path) -> list[str]:
    missing = []
    required = [
        "AGENTS.md",
        "agents/workflow.md",
        "agents/github-project.md",
        "agents/hooks.md",
        "agents/tasks/task-template.md",
        "agents/roles/orchestrator.md",
        "agents/roles/implementer.md",
        "agents/roles/qa-reality-checker.md",
        "agents/roles/code-reviewer.md",
        ".codex/config.toml",
        ".codex/setup.sh",
        ".codex/aok-action.sh",
        ".codex/aok-local-environment.json",
        ".codex/environments/environment.toml",
    ]
    for rel in required:
        if not (path / rel).exists():
            missing.append(rel)
    local_env = collect_codex_local_env(path)
    for item in local_env["files"]:
        if item["ok"] and item["executable"] is False:
            missing.append(f"{item['relativePath']} must be executable")
    if (path / ".codex" / "aok-local-environment.json").exists() and not local_env["manifest"]["ok"]:
        missing.append(".codex/aok-local-environment.json must be a valid AOK Codex local-environment manifest")
    for action in local_env["missingActions"]:
        missing.append(f".codex/aok-local-environment.json missing action {action}")
    for action in local_env.get("invalidActions", []):
        missing.append(f".codex/aok-local-environment.json invalid action {action}")
    return missing


def cmd_project_validate(args: argparse.Namespace) -> int:
    target = Path(args.path).resolve()
    missing = validate_project(target)
    if missing:
        print("Project validation failed. Missing:")
        for rel in missing:
            print(f"- {rel}")
        return 1
    print(f"Project validation passed: {target}")
    return 0


def copy_codex_local_env_templates(target: Path, force: bool = False) -> list[str]:
    template_root = KIT_ROOT / "templates"
    timestamp = datetime.now(timezone.utc).strftime("%Y%m%d%H%M%S")
    backup_root = target / ".aok-backups" / timestamp
    changes: list[str] = []
    for rel_raw in CODEX_LOCAL_ENV_REQUIRED:
        rel = Path(rel_raw)
        src = template_root / rel
        dest = target / rel
        if not src.exists():
            raise AokError(f"Missing Codex local-environment template: {src}")
        dest.parent.mkdir(parents=True, exist_ok=True)
        new_text = src.read_text()
        if not dest.exists():
            dest.write_text(new_text)
            if os.access(src, os.X_OK):
                dest.chmod(0o755)
            changes.append(f"created {rel}")
            continue
        old_text = dest.read_text()
        if old_text == new_text:
            changes.append(f"unchanged {rel}")
            continue
        if not force:
            proposed = dest.with_name(f"{dest.name}.aok-proposed")
            proposed.write_text(new_text)
            diff_path = dest.with_name(f"{dest.name}.aok.diff")
            diff_path.write_text(unified_diff(old_text, new_text, str(rel), str(proposed.relative_to(target))))
            changes.append(f"preserved {rel}; wrote {proposed.relative_to(target)} and {diff_path.relative_to(target)}")
            continue
        backup = backup_file(dest, backup_root, target)
        dest.write_text(new_text)
        if os.access(src, os.X_OK):
            dest.chmod(0o755)
        changes.append(f"updated {rel}; backup {backup.relative_to(target)}")
    return changes


def load_codex_local_env_manifest(path: Path) -> dict:
    manifest_path = path / ".codex" / "aok-local-environment.json"
    data = load_json(manifest_path, {})
    if not isinstance(data, dict):
        raise AokError(f"Invalid Codex local-environment manifest: {manifest_path}")
    return data


def collect_codex_local_env(path: Path) -> dict:
    project = path.resolve()
    files = []
    for rel in CODEX_LOCAL_ENV_REQUIRED:
        item = project / rel
        files.append(
            {
                "path": str(item),
                "relativePath": rel,
                "ok": item.exists(),
                "executable": item.exists() and os.access(item, os.X_OK) if rel.endswith(".sh") else None,
            }
        )
    manifest_path = project / ".codex" / "aok-local-environment.json"
    manifest: dict = {}
    manifest_ok = False
    manifest_error = None
    if manifest_path.exists():
        try:
            manifest = json.loads(manifest_path.read_text())
            manifest_ok = manifest.get("kind") == "aok-codex-local-environment"
        except json.JSONDecodeError as exc:
            manifest_error = str(exc)
    actions = manifest.get("actions", []) if isinstance(manifest, dict) else []
    action_names = [item.get("name") for item in actions if isinstance(item, dict)]
    missing_actions = [name for name in CODEX_LOCAL_ENV_ACTIONS if name not in action_names]
    invalid_actions = []
    for action in actions:
        if not isinstance(action, dict):
            invalid_actions.append("<non-object>")
            continue
        name = action.get("name", "<unnamed>")
        if not action.get("command"):
            invalid_actions.append(str(name))
    environment_path = project / ".codex" / "environments" / "environment.toml"
    environment_ok = False
    environment_error = None
    environment_actions: list[str] = []
    environment_setup = None
    if environment_path.exists():
        try:
            environment_data = load_simple_environment_toml(environment_path)
            environment_setup = (environment_data.get("setup") or {}).get("script")
            environment_actions = [
                str(item.get("name"))
                for item in environment_data.get("actions", [])
                if isinstance(item, dict) and item.get("name") and item.get("command")
            ]
            environment_ok = (
                environment_data.get("version") == 1
                and environment_setup == ".codex/setup.sh"
                and not [name for name in CODEX_LOCAL_ENV_ACTIONS if name not in environment_actions]
            )
        except Exception as exc:  # noqa: BLE001 - validation should report parse errors, not crash
            environment_error = str(exc)
    setup_default = (manifest.get("setupScripts") or {}).get("default") if isinstance(manifest, dict) else None
    codex_generated_config = manifest.get("codexGeneratedConfig", {}) if isinstance(manifest, dict) else {}
    templates_ok = (
        all(item["ok"] for item in files)
        and all(item["executable"] is not False for item in files)
        and manifest_ok
        and environment_ok
        and not missing_actions
        and not invalid_actions
        and setup_default == ".codex/setup.sh"
    )
    return {
        "kind": "aok-codex-local-environment-report",
        "projectPath": str(project),
        "docs": CODEX_LOCAL_ENV_DOCS_URL,
        "templatesOk": templates_ok,
        "files": files,
        "manifest": {
            "path": str(manifest_path),
            "ok": manifest_ok,
            "error": manifest_error,
            "version": manifest.get("version") if isinstance(manifest, dict) else None,
        },
        "setupScript": setup_default,
        "environmentToml": {
            "path": str(environment_path),
            "ok": environment_ok,
            "error": environment_error,
            "setupScript": environment_setup,
            "actions": environment_actions,
        },
        "actions": actions,
        "missingActions": missing_actions,
        "invalidActions": invalid_actions,
        "codexGeneratedConfig": codex_generated_config
        or {
            "status": "unknown",
            "reason": "No AOK Codex local-environment manifest was found.",
        },
    }


def cmd_codex_local_env_init(args: argparse.Namespace) -> int:
    target = Path(args.path).resolve()
    if not target.exists() or not target.is_dir():
        raise AokError(f"Target is not a directory: {target}")
    changes = copy_codex_local_env_templates(target, force=args.force)
    print(f"Initialized Codex local environment: {target}")
    for change in changes:
        print(f"- {change}")
    print("Register .codex/setup.sh and .codex/aok-action.sh actions in Codex App settings.")
    return 0


def cmd_codex_local_env_validate(args: argparse.Namespace) -> int:
    target = Path(args.path).resolve()
    report = collect_codex_local_env(target)
    if getattr(args, "json", False):
        print(json.dumps(report, indent=2))
    else:
        for item in report["files"]:
            detail = item["path"]
            if item["executable"] is False:
                detail = f"{detail} (not executable)"
            print_result(item["relativePath"], bool(item["ok"]) and item["executable"] is not False, detail)
        print_result("manifest", report["manifest"]["ok"], report["manifest"]["path"])
        print_result("environment.toml", report["environmentToml"]["ok"], report["environmentToml"]["path"])
        for missing in report["missingActions"]:
            print_result(f"action {missing}", False)
        for invalid in report["invalidActions"]:
            print_result(f"action {invalid}", False, "missing command")
        print_result("Codex generated config schema", True, report["codexGeneratedConfig"].get("status", "unknown"))
    return 0 if report["templatesOk"] else 1


def cmd_codex_local_env_actions(args: argparse.Namespace) -> int:
    target = Path(args.path).resolve()
    report = collect_codex_local_env(target)
    if report["missingActions"]:
        raise AokError(f"Codex local-environment actions are incomplete: {', '.join(report['missingActions'])}")
    if report["invalidActions"]:
        raise AokError(f"Codex local-environment actions are malformed: {', '.join(report['invalidActions'])}")
    for action in report["actions"]:
        print(f"{action['name']}: {action['command']}")
    return 0


def render_swarmd_projection(task: dict, roles: list[dict]) -> dict:
    callsign = task.get("assigneeRole")
    assignee = "implementer"
    if callsign:
        for role in roles:
            if role.get("id") == callsign:
                assignee = role.get("callsign", role.get("name", role.get("id")))
                break
    assignee = str(assignee or "implementer")
    title = task.get("title", task.get("id", "unnamed task"))
    spec = task.get("spec", task.get("description", ""))
    return {
        "task.create": {
            "title": title,
            "spec": spec,
            "assignee": assignee,
            "phase": task.get("phase", "planned"),
        },
        "memory.put": {
            "namespace": "decision",
            "key": f"{title.lower().replace(' ', '-')}-decision",
            "content": task.get("defaultDecision", f"Follow neutral AOK process for {title}."),
        },
        "event.append": {
            "type": "aok.task.packet.generated",
            "actor": assignee,
            "payload": {
                "taskPacket": task.get("id", title),
                "status": task.get("status", "pending"),
            },
        },
    }


def render_pack_payload(pack_name: str, pack_manifest: dict, content: dict, target: str) -> dict:
    roles = content.get("roles", [])
    skills = content.get("skills", [])
    hooks = content.get("hooks", [])
    templates = content.get("templates", [])
    task_packets = content.get("taskPackets", [])
    task_projection = [
        {
            **task,
            "swarmd": render_swarmd_projection(task, roles),
        }
        for task in task_packets
    ]

    base = {
        "kind": "aok-pack-render",
        "version": pack_manifest.get("version", "0.1.0"),
        "pack": {
            "name": pack_name,
            "sourceRepo": pack_manifest.get("sourceRepo"),
            "kind": pack_manifest.get("kind", "pack"),
            "description": pack_manifest.get("description"),
            "supportedTargets": pack_manifest.get("supportedTargets", []),
            "concepts": pack_manifest.get("concepts", []),
        },
        "source": {
            "manifest": f"packs/{pack_name}/pack.json",
            "content": f"packs/{pack_name}/{pack_manifest.get('neutralContent', 'pack.content.json')}",
        },
        "target": target,
        "renderedAt": datetime.now(timezone.utc).isoformat(timespec="seconds"),
        "roles": roles,
        "hooks": hooks,
        "skills": skills,
        "templates": templates,
        "taskPackets": task_projection,
        "targetRender": pack_manifest.get("targetRender", {}).get(target, {}),
        "concepts": {
            "roles": [item.get("id") for item in roles if isinstance(item, dict) and item.get("id")],
            "hooks": [item.get("id") for item in hooks if isinstance(item, dict) and item.get("id")],
            "skills": [item.get("id") for item in skills if isinstance(item, dict) and item.get("id")],
            "templates": [item.get("id") for item in templates if isinstance(item, dict) and item.get("id")],
            "taskPackets": [item.get("id") for item in task_packets if isinstance(item, dict) and item.get("id")],
        },
    }

    if target == "claude-code":
        plugin_path = KIT_ROOT / "packs" / pack_name / "claude-code" / "plugin.json"
        plugin = {}
        if plugin_path.exists():
            plugin = load_json(plugin_path, {})
        return {
            **base,
            "targetContract": "claude-code-toolbox-compatible",
            "pluginJson": plugin,
            "compatibility": {
                "hookContracts": "hook commands and plugin.json",
                "skillContracts": [item.get("sourcePath") for item in skills if isinstance(item, dict)],
            },
        }

    if target == "codex":
        return {
            **base,
            "targetContract": "codex-agent",
            "notes": ["Rendered into Codex JSON contract for local adoption."],
            "mcpConfig": {
                "mcpServers": {
                    "swarmd": {
                        "command": "swarmd",
                        "args": ["mcp"],
                    }
                }
            },
        }

    return {
        **base,
        "targetContract": f"{target}-agent",
        "notes": [f"Rendered as structured JSON contract for {target}."],
    }


def cmd_render_pack(args: argparse.Namespace) -> int:
    targets = resolve_targets(args.target)
    manifest, pack_dir = load_pack_manifest(args.pack)
    pack_name = manifest.get("name") or args.pack
    content, _ = load_pack_content(pack_name, pack_dir, manifest)
    for target in targets:
        out = normalize_pack_output(pack_name, target, Path(args.out) if args.out else None, len(targets))
        rendered = render_pack_payload(pack_name, manifest, content, target)
        write_json(out, rendered)
        print(f"Wrote render: {out}")
    return 0


def cmd_render_all(args: argparse.Namespace) -> int:
    targets = resolve_targets(args.target)
    pack_dirs = find_pack_dirs()
    if not pack_dirs:
        raise AokError("No packs found.")

    output_root = Path(args.out) if args.out else (KIT_ROOT / "build" / "renders")
    for pack_name in pack_dirs:
        manifest_path = KIT_ROOT / "packs" / pack_name / "pack.json"
        if not manifest_path.exists():
            continue
        manifest = load_json(manifest_path, {})
        if not isinstance(manifest, dict):
            continue
        content, _ = load_pack_content(pack_name, manifest_path.parent, manifest)
        for target in targets:
            out_dir = output_root / target
            out = out_dir / f"{pack_name}.json"
            rendered = render_pack_payload(pack_name, manifest, content, target)
            write_json(out, rendered)
            print(f"Wrote render: {out}")
    return 0


def item_id(item: dict, fallback: str) -> str:
    value = str(item.get("id") or item.get("name") or fallback)
    return re.sub(r"[^a-zA-Z0-9_.-]+", "-", value).strip("-") or fallback


def write_bundle_item_files(bundle_dir: Path, section: str, items: list[dict]) -> list[str]:
    written: list[str] = []
    if not items:
        return written
    section_dir = bundle_dir / section
    section_dir.mkdir(parents=True, exist_ok=True)
    for idx, item in enumerate(items, start=1):
        if not isinstance(item, dict):
            continue
        rel = Path(section) / f"{item_id(item, f'{section}-{idx}')}.json"
        write_json(bundle_dir / rel, item)
        written.append(str(rel))
    return written


def markdown_list(title: str, items: list[dict], fields: tuple[str, ...]) -> str:
    lines = [f"# {title}", ""]
    if not items:
        lines.append("No items.")
        return "\n".join(lines) + "\n"
    for item in items:
        if not isinstance(item, dict):
            continue
        lines.append(f"## {item.get('name') or item.get('title') or item.get('id')}")
        lines.append("")
        for field in fields:
            value = item.get(field)
            if value is None:
                continue
            if isinstance(value, list):
                lines.append(f"- {field}: {', '.join(str(part) for part in value)}")
            elif isinstance(value, dict):
                lines.append(f"- {field}: `{json.dumps(value, sort_keys=True)}`")
            else:
                lines.append(f"- {field}: {value}")
        lines.append("")
    return "\n".join(lines)


def copy_bundle_source(base: Path, rel: str, bundle_dir: Path, copied: list[str]) -> None:
    src = (base / rel).resolve()
    if not src.exists():
        return
    try:
        source_rel = src.relative_to(KIT_ROOT.resolve())
    except ValueError as exc:
        raise AokError(f"Refusing to copy source outside kit root: {rel}") from exc
    dest = bundle_dir / "sources" / source_rel
    dest.parent.mkdir(parents=True, exist_ok=True)
    if src.is_dir():
        if dest.exists():
            shutil.rmtree(dest)
        shutil.copytree(src, dest)
    else:
        shutil.copy2(src, dest)
    copied.append(str(Path("sources") / rel))


def bundle_readme(pack_name: str, target: str, support_level: str) -> str:
    return f"""# {pack_name} for {target}

This bundle was generated by Agent Operating Kit.

- Pack: `{pack_name}`
- Target: `{target}`
- Support level: `{support_level}`
- Contract: `aok-bundle.json`

Use this directory as the importable, self-contained representation of the AOK
pack for the target. Native target installers may consume the same contract and
included source files.
"""


def render_target_bundle(pack_name: str, target: str, out_dir: Path) -> Path:
    manifest, pack_dir = load_pack_manifest(pack_name)
    pack_name = manifest.get("name") or pack_name
    content, _ = load_pack_content(pack_name, pack_dir, manifest)
    bundle_dir = out_dir / target / pack_name
    if bundle_dir.exists():
        shutil.rmtree(bundle_dir)
    bundle_dir.mkdir(parents=True, exist_ok=True)

    rendered = render_pack_payload(pack_name, manifest, content, target)
    target_render = manifest.get("targetRender", {}).get(target, {})
    support_level = target_render.get("supportLevel") or target_render.get("status", "generated")
    source_files: list[str] = []
    source_refs = set()
    for refs in (manifest.get("sourceRefs") or {}).values():
        if isinstance(refs, list):
            source_refs.update(ref for ref in refs if isinstance(ref, str))
    for ref in target_render.get("sourceRefs", []) if isinstance(target_render, dict) else []:
        if isinstance(ref, str):
            source_refs.add(ref)
    for ref in sorted(source_refs):
        copy_bundle_source(pack_dir, ref, bundle_dir, source_files)

    sections = {
        "roles": content.get("roles", []),
        "hooks": content.get("hooks", []),
        "skills": content.get("skills", []),
        "templates": content.get("templates", []),
        "task-packets": content.get("taskPackets", []),
    }
    item_files: list[str] = []
    for section, items in sections.items():
        if isinstance(items, list):
            item_files.extend(write_bundle_item_files(bundle_dir, section, items))

    (bundle_dir / "roles.md").write_text(markdown_list("Roles", content.get("roles", []), ("callsign", "responsibilities", "escalation")))
    (bundle_dir / "hooks.md").write_text(markdown_list("Hooks", content.get("hooks", []), ("event", "matcher", "command", "severity", "description")))
    (bundle_dir / "skills.md").write_text(markdown_list("Skills", content.get("skills", []), ("description", "sourcePath", "inputs")))
    (bundle_dir / "tasks.md").write_text(markdown_list("Task Packets", content.get("taskPackets", []), ("title", "phase", "assigneeRole", "verification")))

    if target == "codex":
        write_json(
            bundle_dir / ".codex-plugin" / "plugin.json",
            {
                "name": f"aok-{pack_name}",
                "version": manifest.get("version", "0.1.0"),
                "description": manifest.get("description", ""),
                "aokPack": pack_name,
            },
        )
    elif target == "claude-code":
        claude_src = pack_dir / "claude-code"
        if claude_src.exists():
            shutil.copytree(claude_src, bundle_dir / "claude-code")
    else:
        write_json(
            bundle_dir / "import.json",
            {
                "kind": "aok-target-import",
                "target": target,
                "pack": pack_name,
                "contract": "aok-bundle.json",
                "readme": "README.md",
            },
        )

    bundle = {
        "kind": "aok-bundle",
        "version": manifest.get("version", "0.1.0"),
        "pack": pack_name,
        "target": target,
        "supportLevel": support_level,
        "generatedAt": datetime.now(timezone.utc).isoformat(timespec="seconds"),
        "contract": rendered,
        "files": sorted(["README.md", "roles.md", "hooks.md", "skills.md", "tasks.md", *item_files, *source_files]),
        "sourceContentIncluded": True,
    }
    write_json(bundle_dir / "aok-bundle.json", bundle)
    (bundle_dir / "README.md").write_text(bundle_readme(pack_name, target, support_level))
    return bundle_dir


def write_bundle_index(root: Path, bundles: list[Path]) -> Path:
    entries = []
    for bundle in sorted(bundles):
        contract = bundle / "aok-bundle.json"
        if not contract.exists():
            continue
        data = load_json(contract, {})
        entries.append(
            {
                "pack": data.get("pack"),
                "target": data.get("target"),
                "supportLevel": data.get("supportLevel"),
                "path": str(bundle.relative_to(root)),
                "contract": str((bundle / "aok-bundle.json").relative_to(root)),
            }
        )
    index = {
        "kind": "aok-bundle-index",
        "version": plugin_version(),
        "generatedAt": datetime.now(timezone.utc).isoformat(timespec="seconds"),
        "bundles": entries,
    }
    out = root / "index.json"
    write_json(out, index)
    return out


def cmd_render_bundle(args: argparse.Namespace) -> int:
    targets = resolve_targets(args.target)
    output_root = Path(args.out) if args.out else (KIT_ROOT / "build" / "bundles")
    bundles = []
    for target in targets:
        bundle = render_target_bundle(args.pack, target, output_root)
        bundles.append(bundle)
        print(f"Wrote bundle: {bundle}")
    index = write_bundle_index(output_root, bundles)
    print(f"Wrote bundle index: {index}")
    return 0


def cmd_render_bundles(args: argparse.Namespace) -> int:
    targets = resolve_targets(args.target)
    output_root = Path(args.out) if args.out else (KIT_ROOT / "build" / "bundles")
    bundles = []
    for pack_name in find_pack_dirs():
        if not (KIT_ROOT / "packs" / pack_name / "pack.json").exists():
            continue
        for target in targets:
            bundle = render_target_bundle(pack_name, target, output_root)
            bundles.append(bundle)
            print(f"Wrote bundle: {bundle}")
    index = write_bundle_index(output_root, bundles)
    print(f"Wrote bundle index: {index}")
    return 0


ISSUE_RE = re.compile(r"github\.com/(?P<owner>[^/]+)/(?P<repo>[^/]+)/issues/(?P<num>\d+)")
PR_RE = re.compile(r"github\.com/(?P<owner>[^/]+)/(?P<repo>[^/]+)/pull/(?P<num>\d+)")


def parse_github_ref(ref: str) -> tuple[str, str, str, str] | None:
    for kind, regex in (("issue", ISSUE_RE), ("pr", PR_RE)):
        match = regex.search(ref)
        if match:
            return kind, match.group("owner"), match.group("repo"), match.group("num")
    return None


def gh_view(ref: str) -> dict:
    parsed = parse_github_ref(ref)
    if not parsed:
        raise AokError("Only GitHub issue and PR URLs are supported by this local CLI implementation.")
    kind, owner, repo, num = parsed
    full_repo = f"{owner}/{repo}"
    if kind == "issue":
        cmd = [
            "gh",
            "issue",
            "view",
            num,
            "--repo",
            full_repo,
            "--comments",
            "--json",
            "title,body,labels,state,comments,assignees,milestone,projectItems,url",
        ]
    else:
        cmd = [
            "gh",
            "pr",
            "view",
            num,
            "--repo",
            full_repo,
            "--comments",
            "--json",
            "title,body,state,headRefName,baseRefName,files,commits,checks,reviews,comments,url",
        ]
    result = run(cmd)
    data = json.loads(result.stdout)
    data["_kind"] = kind
    data["_repo"] = full_repo
    data["_number"] = num
    return data


def cmd_task_sync(args: argparse.Namespace) -> int:
    data = gh_view(args.ref)
    print(json.dumps(data, indent=2))
    return 0


def extract_section(body: str, heading: str) -> str:
    pattern = re.compile(rf"^##\s+{re.escape(heading)}\s*$", re.IGNORECASE | re.MULTILINE)
    match = pattern.search(body or "")
    if not match:
        return ""
    start = match.end()
    next_heading = re.search(r"^##\s+", body[start:], re.MULTILINE)
    end = start + next_heading.start() if next_heading else len(body)
    return body[start:end].strip()


def task_packet_markdown(data: dict) -> str:
    body = data.get("body") or ""
    problem = extract_section(body, "Problem") or data.get("title", "")
    scope = extract_section(body, "Scope")
    criteria = extract_section(body, "Acceptance Criteria")
    target_repo = extract_section(body, "Target Repo") or data.get("_repo", "")
    verification = extract_section(body, "Verification")
    risks = extract_section(body, "Risks / Blockers")
    url = data.get("url", "")
    kind = data.get("_kind", "item")
    issue = url if kind == "issue" else ""
    pr = url if kind == "pr" else ""

    return f"""# Agent Task Packet

## Metadata

| Field | Value |
|---|---|
| Project Item | |
| Issue | {issue} |
| Pull Request | {pr} |
| Target Repo | {target_repo} |
| Branch | |
| Status | |
| Phase | |
| Priority | |
| Attempt | 0 |
| Primary Agent | |
| QA Agent | |

## Problem

{problem}

## Scope

{scope or "In scope:\n-\n\nOut of scope:\n-"}

## Acceptance Criteria

{criteria or "- [ ]"}

## Context

Relevant files:
-

Relevant docs:
-

Dependencies:
-

Risks / Blockers:
{risks or "-"}

## Pre-Hook Results

- `pre_project_sync`:
- `pre_scope_check`:
- `pre_agent_select`:
- `pre_worktree`:
- `pre_risk_check`:

## Implementation Notes

## Verification Plan

{verification or "Commands or evidence required:\n-"}

## QA Verdict

Verdict: `PENDING`

Evidence:
-

Failures:
-

## GitHub Update Log

-

## Final Summary
"""


def cmd_task_packet(args: argparse.Namespace) -> int:
    data = gh_view(args.ref)
    packet = task_packet_markdown(data)
    if args.output:
        out = Path(args.output)
        out.parent.mkdir(parents=True, exist_ok=True)
        out.write_text(packet)
        print(f"Wrote {out}")
    else:
        print(packet)
    return 0


def read_packet(path: str) -> str:
    packet_path = Path(path)
    if not packet_path.exists():
        raise AokError(f"Task packet not found: {packet_path}")
    return packet_path.read_text()


def section_present(text: str, heading: str) -> bool:
    return re.search(rf"^##\s+{re.escape(heading)}\s*$", text, re.MULTILINE) is not None


def section_has_content(text: str, heading: str) -> bool:
    content = extract_section(text, heading)
    stripped = re.sub(r"[-\[\]\s`:_|]", "", content)
    return bool(stripped)


def cmd_hooks_pre(args: argparse.Namespace) -> int:
    text = read_packet(args.packet)
    checks = {
        "Problem": section_has_content(text, "Problem"),
        "Acceptance Criteria": section_has_content(text, "Acceptance Criteria"),
        "Verification Plan": section_has_content(text, "Verification Plan"),
        "Metadata": section_present(text, "Metadata"),
    }
    target_repo_ok = bool(re.search(r"\|\s*Target Repo\s*\|\s*[^|\s][^|]*\|", text))
    checks["Target Repo"] = target_repo_ok
    failed = [name for name, ok in checks.items() if not ok]
    if failed:
        print("Pre-hooks failed. Missing or incomplete:")
        for name in failed:
            print(f"- {name}")
        return 1
    print("Pre-hooks passed.")
    print("- pre_project_sync: packet present")
    print("- pre_scope_check: required scope fields present")
    print("- pre_agent_select: role fields available")
    print("- pre_worktree: run repo-local git checks before edits")
    print("- pre_risk_check: inspect risks before implementation")
    return 0


def cmd_hooks_after(args: argparse.Namespace) -> int:
    text = read_packet(args.packet)
    has_qa = "Verdict: `PENDING`" not in text and "Verdict:" in text
    has_summary = section_has_content(text, "Final Summary") or section_has_content(text, "Implementation Notes")
    if not has_summary:
        print("After-hooks warning: final summary or implementation notes are still empty.")
    print("## Agent Update")
    print()
    print("Status:")
    print("Agent:")
    print("Summary:")
    print("Verification:")
    print("Evidence:")
    print("Next:")
    print("Blockers:")
    if not has_qa:
        print()
        print("Warning: QA verdict is still pending.", file=sys.stderr)
    return 0


def candidate_history_files(path: Path) -> list[Path]:
    names = []
    for pattern in ("**/*.md", "**/*.txt", "**/*.log"):
        names.extend(path.glob(pattern))
    ignored_parts = {".git", "node_modules", "dist", "build", ".venv", "__pycache__"}
    result = []
    for item in sorted(set(names)):
        if any(part in ignored_parts for part in item.parts):
            continue
        if item.is_file() and item.stat().st_size <= 500_000:
            result.append(item)
    return result


def summarize_history(path: Path) -> str:
    keywords = (
        "Agent Update",
        "Acceptance Criteria",
        "Verification",
        "QA",
        "Verdict:",
        "GitHub Update",
        "Final Summary",
        "Blocker",
        "Escalation",
    )
    lines = ["# Agent History Import", ""]
    lines.append(f"Source: {path}")
    lines.append("")
    files = candidate_history_files(path)
    matched = 0
    for file_path in files:
        text = file_path.read_text(errors="ignore")
        hits = [kw for kw in keywords if kw.lower() in text.lower()]
        if not hits:
            continue
        matched += 1
        rel = file_path.relative_to(path)
        title_match = re.search(r"^#\s+(.+)$", text, re.MULTILINE)
        title = title_match.group(1).strip() if title_match else rel.name
        lines.append(f"## {rel}")
        lines.append("")
        lines.append(f"- Title: {title}")
        lines.append(f"- Signals: {', '.join(hits)}")
        first_update = re.search(r"^##\s+Agent Update\s*$", text, re.IGNORECASE | re.MULTILINE)
        if first_update:
            lines.append("- Contains agent update block")
        final_summary = extract_section(text, "Final Summary")
        if final_summary:
            compact = " ".join(final_summary.split())[:240]
            lines.append(f"- Final summary excerpt: {compact}")
        lines.append("")
    lines.append("## Result")
    lines.append("")
    lines.append(f"- Scanned files: {len(files)}")
    lines.append(f"- Matched files: {matched}")
    lines.append("- Hidden chat/session memory was not used.")
    return "\n".join(lines) + "\n"


def cmd_import_history(args: argparse.Namespace) -> int:
    source = Path(args.path).resolve()
    if not source.exists() or not source.is_dir():
        raise AokError(f"Source is not a directory: {source}")
    report = summarize_history(source)
    if args.output:
        out = Path(args.output)
        out.parent.mkdir(parents=True, exist_ok=True)
        out.write_text(report)
        print(f"Wrote {out}")
    else:
        print(report)
    return 0


def enabled_pack_names(raw: list[str]) -> list[str]:
    if not raw or raw == ["all"]:
        return [CLAUDE_ROOT_PLUGIN, *find_pack_dirs()]
    allowed = {CLAUDE_ROOT_PLUGIN, *find_pack_dirs()}
    unknown = sorted(set(raw) - allowed)
    if unknown:
        raise AokError(f"Unknown Claude plugin or pack(s): {', '.join(unknown)}")
    return raw


def cmd_claude_setup(args: argparse.Namespace) -> int:
    home = user_home(getattr(args, "home", None))
    settings_path = Path(args.settings).expanduser() if args.settings else home / ".claude" / "settings.json"
    marketplace_path = (
        Path(args.marketplace_path).expanduser().resolve()
        if args.marketplace_path
        else (KIT_ROOT / "adapters" / "claude-code" / "marketplace").resolve()
    )
    if not marketplace_path.exists():
        raise AokError(f"Claude Code marketplace path does not exist: {marketplace_path}")

    settings_path.parent.mkdir(parents=True, exist_ok=True)
    if settings_path.exists():
        backup = settings_path.with_name(
            f"{settings_path.name}.aok-backup-{datetime.now(timezone.utc).strftime('%Y%m%d%H%M%S')}"
        )
        shutil.copy2(settings_path, backup)
    else:
        backup = None

    data = load_json(settings_path, {})
    if not isinstance(data, dict):
        raise AokError(f"Claude Code settings must be a JSON object: {settings_path}")
    marketplaces = data.setdefault("extraKnownMarketplaces", {})
    if not isinstance(marketplaces, dict):
        raise AokError("extraKnownMarketplaces must be an object")
    marketplaces[CLAUDE_MARKETPLACE_NAME] = {
        "source": {
            "source": "directory",
            "path": str(marketplace_path),
        }
    }

    enabled = data.setdefault("enabledPlugins", {})
    if not isinstance(enabled, dict):
        raise AokError("enabledPlugins must be an object")
    for pack in enabled_pack_names(args.enable):
        enabled[f"{pack}@{CLAUDE_MARKETPLACE_NAME}"] = True

    write_json(settings_path, data)
    print(f"Updated Claude Code settings: {settings_path}")
    if backup:
        print(f"Backup: {backup}")
    print(f"Marketplace: {CLAUDE_MARKETPLACE_NAME} -> {marketplace_path}")
    return 0


def require_json(path: Path, errors: list[str]) -> dict | None:
    try:
        return json.loads(path.read_text())
    except FileNotFoundError:
        errors.append(f"{path.relative_to(KIT_ROOT)}: missing")
    except json.JSONDecodeError as exc:
        errors.append(f"{path.relative_to(KIT_ROOT)}: invalid JSON: {exc}")
    return None


def validate_required_files(errors: list[str]) -> None:
    required = [
        "README.md",
        "CHANGELOG.md",
        "LICENSE",
        ".codex-plugin/plugin.json",
        "hooks.json",
        "core/model.md",
        "core/examples/skill.example.json",
        "core/examples/role.example.json",
        "core/examples/hook.example.json",
        "core/examples/task-packet.example.json",
        "docs/architecture.md",
        "docs/swarmd-integration.md",
        "docs/migration-from-claude-code-toolbox.md",
        "docs/install-and-onboarding.md",
        "docs/codex-local-environments.md",
        "docs/project-init-guide.md",
        "docs/targets-support-matrix.md",
        "docs/release-checklist.md",
        "docs/uninstall-and-rollback.md",
        "adapters/claude-code/aok-plugin/plugin.json",
        "adapters/claude-code/aok-plugin/README.md",
        "adapters/claude-code/aok-plugin/skills/aok-setup.md",
        "adapters/claude-code/aok-plugin/skills/aok-doctor.md",
        "adapters/claude-code/aok-plugin/skills/aok-render.md",
        "adapters/claude-code/aok-plugin/skills/aok-migrate-toolbox.md",
        "adapters/claude-code/aok-plugin/skills/aok-pack-discovery.md",
        "schemas/skill.schema.json",
        "schemas/role.schema.json",
        "schemas/hook.schema.json",
        "schemas/task-packet.schema.json",
        "schemas/tool-adapter.schema.json",
        "schemas/pack.schema.json",
        "skills/agent-workflow/SKILL.md",
        "skills/github-project-execution/SKILL.md",
        "skills/code-review/SKILL.md",
        "skills/qa-verification/SKILL.md",
        "skills/project-bootstrap/SKILL.md",
        "templates/AGENTS.md",
